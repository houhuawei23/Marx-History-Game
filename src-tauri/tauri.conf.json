{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "资本轮回与破局",
  "version": "1.5.0",
  "identifier": "com.marx.historygame",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run build:web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "资本：轮回与破局",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
